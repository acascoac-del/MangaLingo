# .dockerignore para el frontend Next.js

# Excluir carpeta de ejemplos del scaffold (importa socket.io-client que no está instalado)
examples/

# Excluir mini-services (no se incluyen en el build del frontend)
mini-services/
upload/
skills/
download/

node_modules/
.next/
out/
build/
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Env (se pasan como environment vars en compose)
.env.local
.env.*.local

# Cache
.eslintcache
.cache/

# Scripts (no se necesitan en el runtime del frontend)
scripts/

# Backend Python (se monta en otro contenedor)
mini-services/

# Extension source (ya está en public/extension/)
extension-src/

# Tool results
tool-results/

# Z-scritps
.zscripts/
